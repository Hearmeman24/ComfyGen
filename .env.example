# RunPod credentials
RUNPOD_API_KEY=rpa_...
RUNPOD_ENDPOINT_ID=your-endpoint-id

# S3-compatible storage (AWS, Cloudflare R2, Backblaze B2, MinIO, etc.)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
S3_REGION=us-east-1
S3_BUCKET=my-comfy-bucket

# Optional: custom S3 endpoint for R2/B2/MinIO/etc.
# S3_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com

# Optional: use tmpfiles.org instead of S3 (testing only, files expire in 1h)
# COMFY_GEN_STORAGE_PROVIDER=tmpfiles
